{
  "name": "lenovo_moto_firmware_downloader",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "main.electron.js",
  "scripts": {
    "// --- Daily Development ---": "",
    "start": "electron .",
    "start:clean": "bun run dev:data:reset && bun run start",
    "start:reset": "rm -rf assets/data/ && rm -rf ~/Library/Application\\ Support/LenovoMotoFirmwareDownloader/ && bun run start",
    "scan:connected-preview": "bun run tooling/dev/scan-connected-preview.ts",
    "// --- Build & Distribution ---": "",
    "build:dev": "bun run qdl:prepare && bun run ffmpeg:prepare && bun run usb:prepare && bun run prepare:all && electron-builder --dir",
    "build:canary": "bun run qdl:prepare && bun run ffmpeg:prepare && bun run usb:prepare && bun run prepare:all && electron-builder --config electron-builder.canary.json",
    "build:stable": "bun run qdl:prepare && bun run ffmpeg:prepare && bun run usb:prepare && bun run prepare:all && electron-builder --config electron-builder.stable.json",
    "// --- Infrastructure & Utils ---": "",
    "web:install": "cd web && bun install",
    "web:build": "cd web && bun run build:desktop",
    "install:all": "bun install && bun run web:install",
    "prepare:all": "bun run web:build && bun run tooling/build/sync-frontend.ts && bun run android-helper:build && bun run system-prompt-dex:build",
    "qdl:prepare": "bun run tooling/build/prepare-qdl.ts",
    "ffmpeg:prepare": "bun run tooling/build/prepare-ffmpeg.ts",
    "usb:prepare": "bun run tooling/build/prepare-usb-addon.ts",
    "android-helper:build": "bun run runtime/bun/features/backup-restore/on-device/restore-helper/build.ts",
    "system-prompt-dex:build": "bun run runtime/bun/features/backup-restore/on-device/system-prompt/build.ts",
    "dev:data:reset": "bun run tooling/dev/reset-dev-data.ts",
    "arch:layers": "bun run tooling/arch/check-layer-boundaries.ts",
    "arch:cycles": "bun run tooling/arch/check-dependency-cycles.ts",
    "arch:check": "bun run arch:layers && bun run arch:cycles",
    "tsc": "bunx tsc -p tsconfig.json --noEmit && bunx tsc -p web/tsconfig.app.json --noEmit",
    "check": "bun run arch:check && bun run tsc && bun run biome:check",
    "biome:format": "bunx --bun @biomejs/biome format --write",
    "biome:lint": "bunx --bun @biomejs/biome lint --write",
    "biome:check": "bunx --bun @biomejs/biome check",
    "biome:fix": "bunx --bun @biomejs/biome check --write",
    "biome:ci": "bunx --bun @biomejs/biome ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.13",
    "@types/stream-buffers": "^3.0.3",
    "@types/yauzl": "^3.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2",
    "rebuild": "^0.1.2",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-credential-web": "^2.1.0",
    "@yume-chan/adb-daemon-webusb": "^2.3.2",
    "@yume-chan/adb-server-node-tcp": "^2.5.2",
    "apie": "github:enigma550/apie#242da8a",
    "apkmirror-downloader": "^2.0.10",
    "archiver": "^7.0.1",
    "fastboot-bun-ts": "github:enigma550/fastboot-bun-ts#21b2313",
    "fflate": "^0.8.2",
    "ffmpeg-static": "^5.3.0",
    "google-play-proto": "^1.3.1",
    "protobufjs": "^8.0.3",
    "spd-tool-bun": "github:enigma550/spd-tool-bun",
    "stream-buffers": "^3.0.2",
    "usb": "^2.17.0",
    "yauzl": "^3.4.0"
  }
}